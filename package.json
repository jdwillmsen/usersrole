{
  "name": "usersrole",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint . --fix",
    "format": "npx prettier src/**/*.{js,jsx,ts,tsx,html,css,scss} --write",
    "jest": "jest",
    "ct": "ng run usersrole:ct",
    "e2e": "ng run usersrole:e2e",
    "ct:ci": "ng run usersrole:ct-ci",
    "e2e:ci": "ng run usersrole:e2e-ci",
    "jest:coverage": "jest --coverage",
    "cypress:coverage": "npx nyc report --reporter=html --reporter=lcov ---reporter=text --reporter=text-summary",
    "clean:coverage": "rm -rf coverage",
    "merge:coverage": "npx istanbul-merge --out coverage/merged-report/coverage-final.json coverage/jest/coverage-final.json coverage/cypress/coverage-final.json",
    "all:coverage": "npx nyc report --report-dir=coverage/merged-report --temp-dir=coverage/merged-report --reporter=html --reporter=lcov --reporter=text --reporter=text-summary --reporter=json-summary --include=src/**/*.ts --exclude=src/main.ts --exclude=src/environments/**",
    "tests:all": "npm run jest:coverage && npm run ct:ci && npm run e2e:ci && npm run merge:coverage && npm run all:coverage",
    "cy:run:e2e": "npx cypress run",
    "cy:run:ct": "npx cypress run --component",
    "cy:parallel:ct": "npx cypress-parallel -s cy:run:ct -t 4 -d src/app",
    "cy:parallel:e2e": "npx cypress-parallel -s cy:run:e2e -t 4 -d cypress/e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.2",
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/material": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/platform-browser-dynamic": "22.0.2",
    "@angular/router": "22.0.2",
    "@angular/service-worker": "22.0.2",
    "@types/tinycolor2": "^1.4.3",
    "ag-grid-angular": "^35.0.0",
    "ag-grid-community": "^35.0.0",
    "clean": "^4.0.2",
    "express": "4.18.2",
    "firebase": "^12.0.0",
    "protobufjs": ">=7.2.4",
    "rxfire": "^6.1.0",
    "rxjs": "7.8.1",
    "semver": ">=7.5.2",
    "tinycolor2": "^1.6.0",
    "tough-cookie": ">=4.1.3",
    "tslib": "2.5.3",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^22.0.0",
    "@angular-builders/jest": "^22.0.0",
    "@angular-devkit/build-angular": "22.0.3",
    "@angular-eslint/builder": "22.0.0",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/schematics": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "@bahmutov/cypress-code-coverage": "^2.6.1",
    "@briebug/jest-schematic": "^2.1.1",
    "@cypress/code-coverage": "^4.0.0",
    "@cypress/schematic": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@jsdevtools/coverage-istanbul-loader": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "angular-eslint": "^22.0.0",
    "check-code-coverage": "^1.10.5",
    "cypress": "^15.0.0",
    "cypress-parallel": "^0.13.0",
    "cypress-split": "^1.5.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^5.2.0",
    "istanbul-lib-coverage": "^3.2.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-fixed-jsdom": "^0.0.11",
    "jest-preset-angular": "^17.0.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "nyc": "^15.1.0",
    "prettier": "^3.4.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.88.2"
  },
  "description": "Users role and authentication template application.",
  "main": "index.js",
  "keywords": [
    "angular",
    "roles",
    "users",
    "authorization",
    "authentication"
  ],
  "author": "Jake Willmsen",
  "license": "ISC"
}
