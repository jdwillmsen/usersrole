{
  "name": "usersrole",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "npx eslint src/**/*.{js,jsx,ts,tsx,html,css} --fix",
    "format": "npx prettier src/**/*.{js,jsx,ts,tsx,html,css,scss} --write",
    "jest": "jest",
    "ct": "ng run usersrole:ct",
    "e2e": "ng run usersrole:e2e",
    "ct:ci": "ng run usersrole:ct-ci",
    "e2e:ci": "ng run usersrole:e2e-ci",
    "jest:coverage": "jest --coverage",
    "cypress:coverage": "npx nyc report --reporter=html --reporter=lcov ---reporter=text --reporter=text-summary",
    "clean:coverage": "rm -rf coverage",
    "merge:coverage": "npx istanbul-merge --out coverage/merged-report/coverage-final.json coverage/jest/coverage-final.json coverage/cypress/coverage-final.json",
    "all:coverage": "npx nyc report --report-dir=coverage/merged-report --temp-dir=coverage/merged-report --reporter=html --reporter=lcov --reporter=text --reporter=text-summary --reporter=json-summary --include=src/**/*.ts --exclude=src/main.ts --exclude=src/environments/**",
    "tests:all": "npm run jest:coverage && npm run ct:ci && npm run e2e:ci && npm run merge:coverage && npm run all:coverage",
    "cy:run:e2e": "npx cypress run",
    "cy:run:ct": "npx cypress run --component",
    "cy:parallel:ct": "npx cypress-parallel -s cy:run:ct -t 4 -d src/app",
    "cy:parallel:e2e": "npx cypress-parallel -s cy:run:e2e -t 4 -d cypress/e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "19.2.25",
    "@angular/cdk": "19.2.19",
    "@angular/common": "19.2.25",
    "@angular/compiler": "19.2.25",
    "@angular/core": "19.2.25",
    "@angular/forms": "19.2.25",
    "@angular/material": "19.2.19",
    "@angular/platform-browser": "19.2.25",
    "@angular/platform-browser-dynamic": "19.2.25",
    "@angular/router": "19.2.25",
    "@angular/service-worker": "19.2.25",
    "@types/tinycolor2": "^1.4.3",
    "ag-grid-angular": "^30.0.6",
    "ag-grid-community": "^30.0.6",
    "clean": "^4.0.2",
    "express": "4.18.2",
    "firebase": "9.22.0",
    "protobufjs": ">=7.2.4",
    "rxfire": "^6.1.0",
    "rxjs": "7.8.1",
    "semver": ">=7.5.2",
    "tinycolor2": "^1.6.0",
    "tough-cookie": ">=4.1.3",
    "tslib": "2.5.3",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^19.0.1",
    "@angular-builders/jest": "^19.0.1",
    "@angular-devkit/build-angular": "19.2.27",
    "@angular-eslint/builder": "19.8.1",
    "@angular-eslint/eslint-plugin": "19.8.1",
    "@angular-eslint/eslint-plugin-template": "19.8.1",
    "@angular-eslint/schematics": "19.8.1",
    "@angular-eslint/template-parser": "19.8.1",
    "@angular/cli": "19.2.27",
    "@angular/compiler-cli": "19.2.25",
    "@bahmutov/cypress-code-coverage": "^2.6.1",
    "@briebug/jest-schematic": "^2.1.1",
    "@cypress/code-coverage": "^3.12.1",
    "@cypress/schematic": "2.5.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@jsdevtools/coverage-istanbul-loader": "^3.0.5",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.2",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "check-code-coverage": "^1.10.5",
    "cypress": "13.3.0",
    "cypress-parallel": "^0.13.0",
    "cypress-split": "^1.5.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "4.2.1",
    "istanbul-lib-coverage": "^3.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.6.4",
    "jest-preset-angular": "^14.6.2",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "nyc": "^15.1.0",
    "prettier": "2.8.8",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.1",
    "typescript": "5.8.3",
    "webpack": "^5.88.2"
  },
  "description": "Users role and authentication template application.",
  "main": "index.js",
  "keywords": [
    "angular",
    "roles",
    "users",
    "authorization",
    "authentication"
  ],
  "author": "Jake Willmsen",
  "license": "ISC"
}
